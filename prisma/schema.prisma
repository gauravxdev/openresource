generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String?        @unique
  usernameUpdatedAt DateTime?
  password      String?
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  emailVerified Boolean        @default(false)
  image         String?
  role          String         @default("user")
  status        String         @default("ACTIVE")
  lastLoginAt   DateTime?
  accounts      Account[]
  loginHistory  LoginHistory[]
  sessions      Session[]
  chats         Chat[]
  resources     Resource[]
  bookmarks     Bookmark[]
  searchUsage   SearchUsage[]
  messageFeedback MessageFeedback[]

  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
  @@map("waitlist")
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
  @@map("newsletter")
}

model Resource {
  id                  String     @id @default(cuid())
  name                String
  description         String
  websiteUrl          String?
  repositoryUrl       String
  alternative         String?
  stars               Int        @default(0)
  forks               Int        @default(0)
  lastCommit          DateTime?
  status              String     @default("PENDING")
  rejectionReason     String?
  addedBy             String?
  image               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  license             String?
  repositoryCreatedAt DateTime?
  shortDescription    String?
  slug                String     @unique
  logo                String?
  oneLiner            String?
  userId              String?
  user                User?      @relation(fields: [userId], references: [id])
  categories          Category[] @relation("CategoryToResource")
  tags                String[]   @default([])
  builtWith           Json?
  bookmarks           Bookmark[]

  @@map("resource")
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  resources Resource[] @relation("CategoryToResource")

  @@map("category")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_history")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  userId     String?
  resourceId String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_log")
}

model Chat {
  id         String        @id @default(cuid())
  title      String        @default("New Chat")
  userId     String
  visibility String        @default("private")
  isPinned   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@index([userId])
  @@map("chat")
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  parts     Json
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("chat_message")
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("bookmark")
}

model SearchUsage {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  count     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("search_usage")
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  chatId    String
  userId    String
  type      String   // "good" or "bad"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([chatId])
  @@index([userId])
  @@index([type])
  @@map("message_feedback")
}
